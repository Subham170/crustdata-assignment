# =============================================================================
# GrowthLens Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Server
PORT=3001
NODE_ENV=development

# =============================================================================
# SUPABASE POSTGRESQL
# =============================================================================
#
# WHERE TO FIND YOUR LINK:
#   Supabase Dashboard → Project Settings (gear icon) → Database
#   → Connection string → Type: URI
#
# You will see a dropdown with connection modes. DO NOT use "Direct connection"
# if you see the red "Not IPv4 compatible" warning (globe with X).
#
# -----------------------------------------------------------------------------
# IPv4 FIX (red cross on "Not IPv4 compatible")
# -----------------------------------------------------------------------------
# The URI you see by default looks like:
#   postgresql://postgres:[YOUR-PASSWORD]@db.abhtddxuqqmqhvjzyqsk.supabase.co:5432/postgres
#
# That host (db.xxx.supabase.co) uses IPv6. Many home/office networks are
# IPv4-only, so Prisma/Node cannot connect → health check fails.
#
# FIX — switch to Connection Pooling (IPv4 compatible):
#   1. Same page: Connection string
#   2. Change dropdown from "Direct connection" → "Connection pooling"
#   3. Copy TWO different URIs (see below)
#
# Alternative: buy Supabase "IPv4 add-on" (paid) to keep direct connection.
# Recommended for this project: use Connection pooling (free).
#
# -----------------------------------------------------------------------------
# WHAT TO PUT IN EACH VARIABLE
# -----------------------------------------------------------------------------
#
# DATABASE_URL  →  Connection pooling → Method: "Transaction" → copy URI
#   - Port is 6543
#   - User looks like: postgres.abhtddxuqqmqhvjzyqsk  (not just "postgres")
#   - Append ?pgbouncer=true at the end if not already present
#   - Used by the running Express app
#
# Example DATABASE_URL:
# DATABASE_URL="postgresql://postgres.abhtddxuqqmqhvjzyqsk:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL  →  Connection pooling → Method: "Session" → copy URI
#   - Port is 5432 (pooler host, NOT db.xxx.supabase.co)
#   - User looks like: postgres.abhtddxuqqmqhvjzyqsk
#   - Used by Prisma migrations only (npm run db:migrate)
#
# Example DIRECT_URL:
# DIRECT_URL="postgresql://postgres.abhtddxuqqmqhvjzyqsk:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"
#
# IMPORTANT — if your database password has special characters, URL-encode them:
#   # → %23    @ → %40    : → %3A    / → %2F    $ → %24    + → %2B    * → %2A
# Example: password "abc#123" becomes "abc%23123"
# Or reset your Supabase DB password to letters+numbers only (easier).
#
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://postgres.abhtddxuqqmqhvjzyqsk:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

DIRECT_URL="postgresql://postgres.abhtddxuqqmqhvjzyqsk:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# =============================================================================
# REDIS (optional for Phase 1; required from Phase 4 for company cache)
# Local: cd backend && docker compose up -d
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# CRUSTDATA (Phase 4+)
# =============================================================================
CRUSTDATA_API_KEY=
CRUSTDATA_API_VERSION=2025-11-01
CRUSTDATA_BASE_URL=https://api.crustdata.com

# =============================================================================
# AI (Phase 6+)
# =============================================================================
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=openai

# =============================================================================
# UPLOADS (Phase 2+)
# =============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
